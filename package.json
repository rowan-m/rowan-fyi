{
  "name": "out-out",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src",
    "lint:sonar": "eslint src -c eslint.sonar.config.js",
    "lint:security": "eslint src -c eslint.security.config.js",
    "depcruise": "depcruise src",
    "format": "prettier --write .",
