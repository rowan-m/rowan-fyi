---
interface Props {
  canonicalUrl: string;
  blueskyUrl?: string;
  mastodonUrl?: string;
}

const { canonicalUrl, blueskyUrl, mastodonUrl } = Astro.props;
---

<section class="social-comments" data-canonical={canonicalUrl} data-bsky={blueskyUrl} data-mastodon={mastodonUrl}>
  <hr />
  <h2>Comments</h2>
  <div id="comments-container">
    <p class="loading">Loading comments from Bluesky and Mastodon...</p>
  </div>
  <p class="comment-cta">
    Join the conversation by replying on <a href={blueskyUrl || "https://bsky.app"}>Bluesky</a> or <a href={mastodonUrl || "https://mastodon.social"}>Mastodon</a>.
  </p>
</section>

<style>
  .social-comments {
    margin-top: 3rem;
  }

  .social-comments h2 {
    margin-bottom: 1.5rem;
  }

  #comments-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .loading {
    font-style: italic;
    color: var(--sec-fg);
  }

  .comment-cta {
    margin-top: 2rem;
    font-size: var(--size-step-0);
    color: var(--sec-fg);
    border-top: 1px solid var(--sec-border);
    padding-top: 1rem;
  }

  :global(.comment) {
    border: 1px solid var(--sec-border);
    padding: 1rem;
    border-radius: 0.25rem;
    background-color: rgba(255, 255, 255, 0.05);
  }

  :global(.comment-header) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  :global(.comment-avatar) {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    object-fit: cover;
  }

  :global(.comment-author-info) {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  :global(.comment-author-name) {
    font-weight: bold;
    color: var(--main-fg);
    text-decoration: none;
  }

  :global(.comment-author-handle) {
    font-size: 0.85em;
    color: var(--sec-fg);
    text-decoration: none;
  }

  :global(.comment-content) {
    font-size: var(--size-step-0);
    line-height: 1.5;
    word-break: break-word;
  }

  :global(.comment-content a) {
    color: var(--main-accent);
  }

  :global(.comment-meta) {
    margin-top: 0.5rem;
    font-size: 0.8em;
    color: var(--sec-fg);
  }

  :global(.comment-replies) {
    margin-left: 1.5rem;
    margin-top: 1rem;
    border-left: 2px solid var(--sec-border);
    padding-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>

<script>
  interface Comment {
    id: string;
    authorName: string;
    authorHandle: string;
    authorAvatar: string;
    authorUrl: string;
    content: string;
    publishedAt: string;
    url: string;
    source: 'bluesky' | 'mastodon';
    replies?: Comment[];
  }

  const CACHE_KEY_PREFIX = 'social-comments-';
  const CACHE_TTL = 5 * 60 * 1000; // 5 minutes

  async function init() {
    const container = document.querySelector('.social-comments') as HTMLElement;
    if (!container) return;

    const canonicalUrl = container.dataset.canonical!;
    const bskyUrl = container.dataset.bsky;
    const mastodonUrl = container.dataset.mastodon;

    // Use a safe key for localStorage
    const cacheKey = CACHE_KEY_PREFIX + canonicalUrl.replace(/[^a-zA-Z0-9]/g, '-');
    const cachedData = localStorage.getItem(cacheKey);

    if (cachedData) {
      const { timestamp, comments } = JSON.parse(cachedData);
      if (Date.now() - timestamp < CACHE_TTL) {
        renderComments(comments);
        return;
      }
    }

    try {
      const comments = await fetchAllComments(canonicalUrl, bskyUrl, mastodonUrl);
      localStorage.setItem(cacheKey, JSON.stringify({
        timestamp: Date.now(),
        comments
      }));
      renderComments(comments);
    } catch (error) {
      console.error('Failed to fetch comments:', error);
      const commentsEl = document.getElementById('comments-container');
      if (commentsEl) {
        commentsEl.innerHTML = '<p class="error">Failed to load comments. Please try again later.</p>';
      }
    }
  }

  async function fetchAllComments(canonicalUrl: string, bskyUrl?: string, mastodonUrl?: string): Promise<Comment[]> {
    const promises = [];

    // Bluesky
    promises.push(fetchBlueskyComments(canonicalUrl, bskyUrl));

    // Mastodon
    promises.push(fetchMastodonComments(canonicalUrl, mastodonUrl));

    const results = await Promise.all(promises);
    let allComments = results.flat();

    // Sort by date
    allComments.sort((a, b) => new Date(a.publishedAt).getTime() - new Date(b.publishedAt).getTime());

    return allComments;
  }

  async function fetchBlueskyComments(canonicalUrl: string, linkedUrl?: string): Promise<Comment[]> {
    let comments: Comment[] = [];

    // If there's a specific linked post, fetch its thread
    if (linkedUrl) {
      try {
        const thread = await fetchBlueskyThread(linkedUrl);
        if (thread) {
           comments.push(thread);
        }
      } catch (e) {
        console.warn('BSky thread fetch failed', e);
      }
    }

    // Search for mentions of the canonical URL
    try {
      const searchUrl = `https://public.api.bsky.app/xrpc/app.bsky.feed.searchPosts?q=${encodeURIComponent(canonicalUrl)}&limit=20`;
      const searchRes = await fetch(searchUrl);
      if (searchRes.ok) {
        const data = await searchRes.json();
        const searchPosts = data.posts || [];
        for (const post of searchPosts) {
          // If this post is the one we already fetched via linkedUrl, skip it
          if (comments.find(c => c.id === post.uri)) continue;

          // Fetch the full thread for each search result to get replies
          try {
            const thread = await fetchBlueskyThreadByUri(post.uri);
            if (thread) {
              comments.push(thread);
              continue;
            }
          } catch (e) {
            console.warn('BSky thread fetch for search result failed', e);
          }
          comments.push(mapBlueskyPost(post));
        }
      }
    } catch (e) {
      console.warn('BSky search failed', e);
    }

    return comments;
  }

  async function fetchBlueskyThread(url: string): Promise<Comment | null> {
    // Support various formats:
    // https://bsky.app/profile/rowan.fyi/post/3lh2k6p6q2c2b
    // at://did:plc:xxx/app.bsky.feed.post/3lh2k6p6q2c2b

    if (url.startsWith('at://')) {
      return fetchBlueskyThreadByUri(url);
    } else if (url.includes('bsky.app/profile/')) {
      const parts = url.split('/');
      const handle = parts[parts.indexOf('profile') + 1];
      const rkey = parts[parts.indexOf('post') + 1];

      try {
        // Resolve handle to DID
        const resolveRes = await fetch(`https://public.api.bsky.app/xrpc/com.atproto.identity.resolveHandle?handle=${handle}`);
        if (!resolveRes.ok) return null;
        const { did } = await resolveRes.json();
        const uri = `at://${did}/app.bsky.feed.post/${rkey}`;
        return fetchBlueskyThreadByUri(uri);
      } catch (e) {
        return null;
      }
    }
    return null;
  }

  async function fetchBlueskyThreadByUri(uri: string): Promise<Comment | null> {
    try {
      const threadRes = await fetch(`https://public.api.bsky.app/xrpc/app.bsky.feed.getPostThread?uri=${uri}`);
      if (!threadRes.ok) return null;
      const data = await threadRes.json();
      const thread = data.thread;

      return mapBlueskyThread(thread);
    } catch (e) {
      return null;
    }
  }

  function mapBlueskyPost(post: any): Comment {
    return {
      id: post.uri,
      authorName: post.author.displayName || post.author.handle,
      authorHandle: post.author.handle,
      authorAvatar: post.author.avatar,
      authorUrl: `https://bsky.app/profile/${post.author.handle}`,
      content: post.record.text,
      publishedAt: post.indexedAt,
      url: `https://bsky.app/profile/${post.author.handle}/post/${post.uri.split('/').pop()}`,
      source: 'bluesky'
    };
  }

  function mapBlueskyThread(thread: any): Comment {
    const comment = mapBlueskyPost(thread.post);
    if (thread.replies && thread.replies.length > 0) {
      comment.replies = thread.replies
        .filter((r: any) => r.post) // Ensure it's not a blocked/deleted post
        .map(mapBlueskyThread);
    }
    return comment;
  }

  async function fetchMastodonComments(canonicalUrl: string, linkedUrl?: string): Promise<Comment[]> {
    let comments: Comment[] = [];

    // Search for mentions of the canonical URL on mastodon.social
    try {
      const searchUrl = `https://mastodon.social/api/v2/search?q=${encodeURIComponent(canonicalUrl)}&type=statuses&limit=20`;
      const searchRes = await fetch(searchUrl);
      if (searchRes.ok) {
        const data = await searchRes.json();
        const statuses = data.statuses || [];
        for (const status of statuses) {
          // For each status, we might want its context (replies)
          const thread = await fetchMastodonThread(status.id);
          if (thread) comments.push(thread);
          else comments.push(mapMastodonStatus(status));
        }
      }
    } catch (e) {
      console.warn('Mastodon search failed', e);
    }

    if (linkedUrl) {
      const parts = linkedUrl.split('/');
      const id = parts[parts.length - 1];
      const thread = await fetchMastodonThread(id);
      if (thread) {
        // Deduplicate
        if (!comments.find(c => c.id === thread.id)) {
          comments.push(thread);
        }
      }
    }

    // Deduplicate
    const uniqueComments = Array.from(new Map(comments.map(c => [c.id, c])).values());
    return uniqueComments;
  }

  async function fetchMastodonThread(id: string): Promise<Comment | null> {
    try {
      const statusRes = await fetch(`https://mastodon.social/api/v1/statuses/${id}`);
      if (!statusRes.ok) return null;
      const status = await statusRes.json();

      const contextRes = await fetch(`https://mastodon.social/api/v1/statuses/${id}/context`);
      if (!contextRes.ok) return mapMastodonStatus(status);
      const context = await contextRes.json();

      const rootComment = mapMastodonStatus(status);

      // Mastodon context gives ancestors and descendants. We want descendants of this post.
      // But context is flat. We need to build a tree.
      // For simplicity, let's just show all descendants as replies if they are direct or indirect.
      // Real tree building is better.

      const descendants = context.descendants || [];
      rootComment.replies = buildMastodonTree(id, descendants);

      return rootComment;
    } catch (e) {
      return null;
    }
  }

  function buildMastodonTree(parentId: string, descendants: any[]): Comment[] {
    return descendants
      .filter(d => d.in_reply_to_id === parentId)
      .map(d => {
        const c = mapMastodonStatus(d);
        c.replies = buildMastodonTree(d.id, descendants);
        return c;
      });
  }

  function mapMastodonStatus(status: any): Comment {
    return {
      id: status.id,
      authorName: status.account.display_name || status.account.username,
      authorHandle: status.account.acct,
      authorAvatar: status.account.avatar,
      authorUrl: status.account.url,
      content: status.content, // HTML
      publishedAt: status.created_at,
      url: status.url,
      source: 'mastodon'
    };
  }

  function renderComments(comments: Comment[]) {
    const container = document.getElementById('comments-container');
    if (!container) return;

    if (comments.length === 0) {
      container.innerHTML = '<p>No comments found yet. Be the first to share your thoughts!</p>';
      return;
    }

    container.innerHTML = '';
    comments.forEach(comment => {
      container.appendChild(createCommentElement(comment));
    });
  }

  function createCommentElement(comment: Comment): HTMLElement {
    const article = document.createElement('article');
    article.className = 'comment';
    article.id = `comment-${comment.id}`;

    const header = document.createElement('div');
    header.className = 'comment-header';

    const avatar = document.createElement('img');
    avatar.className = 'comment-avatar';
    avatar.src = comment.authorAvatar;
    avatar.alt = comment.authorName;

    const authorInfo = document.createElement('div');
    authorInfo.className = 'comment-author-info';

    const authorName = document.createElement('a');
    authorName.className = 'comment-author-name';
    authorName.href = comment.authorUrl;
    authorName.textContent = comment.authorName;

    const authorHandle = document.createElement('a');
    authorHandle.className = 'comment-author-handle';
    authorHandle.href = comment.authorUrl;
    authorHandle.textContent = `@${comment.authorHandle}`;

    authorInfo.appendChild(authorName);
    authorInfo.appendChild(authorHandle);
    header.appendChild(avatar);
    header.appendChild(authorInfo);

    const content = document.createElement('div');
    content.className = 'comment-content';
    if (comment.source === 'mastodon') {
      content.innerHTML = comment.content;
    } else {
      content.textContent = comment.content;
      // Basic linkification for Bluesky
      content.innerHTML = content.innerHTML.replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank">$1</a>');
    }

    const meta = document.createElement('div');
    meta.className = 'comment-meta';
    const dateLink = document.createElement('a');
    dateLink.href = comment.url;
    dateLink.target = '_blank';
    dateLink.textContent = new Date(comment.publishedAt).toLocaleString();
    meta.appendChild(dateLink);

    article.appendChild(header);
    article.appendChild(content);
    article.appendChild(meta);

    if (comment.replies && comment.replies.length > 0) {
      const repliesContainer = document.createElement('div');
      repliesContainer.className = 'comment-replies';
      comment.replies.forEach(reply => {
        repliesContainer.appendChild(createCommentElement(reply));
      });
      article.appendChild(repliesContainer);
    }

    return article;
  }

  init();
</script>
