    const form = document.getElementById("verify-form");
    const submitBtn = document.getElementById("submit-btn");

    if (form && submitBtn) {
      form.addEventListener("submit", () => {
        submitBtn.setAttribute("disabled", "true");
      });
    }
  </script>
