---
export const prerender = false;

Astro.response.headers.set(
  "Origin-Trial",
  "AhXp8ak/QLxZjlTcDhudtMFPwVwV3MrqSIO/OODXG2IknnKycOuqn+z/h195Ob/0B4vF42nTcV8lQbESLVggNQQAAABceyJvcmlnaW4iOiJodHRwczovL3Jvd2FuLmZ5aTo0NDMiLCJmZWF0dXJlIjoiRW1haWxWZXJpZmljYXRpb25Qcm90b2NvbCIsImV4cGlyeSI6MTc5NDg3MzYwMH0=",
);

import MetaOnlyLayout from "@/layouts/MetaOnlyLayout.astro";
import { importJWK, jwtVerify, decodeJwt, decodeProtectedHeader } from "jose";
import type { JWK } from "jose";

interface VerificationResult {
  email: string;
  evt: Record<string, unknown>;
  kb: Record<string, unknown>;
}

interface EvtPayload {
  email: string;
  cnf?: {
    jwk?: JWK;
  };
}

let verificationResult: VerificationResult | null = null;
let errorMsg = "";
let submittedEmail = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    submittedEmail = formData.get("email") as string;
    const rawToken = formData.get("token") as string;

    if (rawToken) {
      // Split the token into EVT and KB-JWT
      const parts = rawToken.split("~");
      if (parts.length < 2) {
        throw new Error(
          "Invalid token format. Missing Key Binding JWT (KB-JWT) separator '~'.",
        );
      }
      const evtJwt = parts[0];
      const kbJwt = parts[1];

      // Decode EVT payload to dynamically discover the issuer (iss)
      const decodedPayload = decodeJwt(evtJwt);
      const iss = decodedPayload.iss;
      if (!iss) {
        throw new Error("EVT is missing the issuer ('iss') claim.");
      }

      let evtPayload: EvtPayload;

      // 1. Verify EVT dynamically by performing discovery on the external issuer
      const discoveryUrl = `${iss}/.well-known/email-verification`;
      const metadataResponse = await fetch(discoveryUrl);
      if (!metadataResponse.ok) {
        throw new Error(
          `Failed to discover issuer metadata at ${discoveryUrl}: ${metadataResponse.statusText}`,
        );
      }
      const metadata = await metadataResponse.json();
      const jwksUri = metadata.jwks_uri;
      if (!jwksUri) {
        throw new Error(
          `Issuer metadata at ${discoveryUrl} is missing 'jwks_uri'.`,
        );
      }

      // Fetch remote JWKS
      const jwksResponse = await fetch(jwksUri);
      if (!jwksResponse.ok) {
        throw new Error(`Failed to fetch JWKS from ${jwksUri}`);
      }
      const jwksData = await jwksResponse.json();

      // The token header might have an empty kid and Gmail / Google's JWKS omits kids.
      // We must iterate through all keys and attempt verification.
      const headerAlg = decodedPayload?.alg || "EdDSA";
      let verifiedPayload = null;

      for (const jwk of jwksData.keys) {
        try {
          const publicKey = await importJWK(jwk, headerAlg);
          const { payload } = await jwtVerify(evtJwt, publicKey);
          verifiedPayload = payload;
          break; // Success, stop trying keys
        } catch {
          // Signature verification failed for this key, try the next one
          continue;
        }
      }

      if (!verifiedPayload) {
        throw new Error(
          "Verification error: JWKSNoMatchingKey: no applicable key found in the JSON Web Key Set",
        );
      }
      evtPayload = verifiedPayload as unknown as EvtPayload;

      // 2. Extract browser's public key from cnf.jwk
      const browserJwk = evtPayload.cnf?.jwk;
      if (!browserJwk) {
        throw new Error(
          "EVT payload is missing the browser's ephemeral public key (cnf.jwk).",
        );
      }

      // 3. Verify KB-JWT using browser's public key
      const kbHeader = decodeProtectedHeader(kbJwt);
      const kbAlg = kbHeader.alg || "ES256";
      const browserPublicKey = await importJWK(browserJwk, kbAlg);
      const { payload: kbPayload } = await jwtVerify(kbJwt, browserPublicKey);

      // 4. Verify email match
      if (evtPayload.email !== submittedEmail) {
        throw new Error(
          `Email mismatch: Form input is '${submittedEmail}', but verified token holds '${evtPayload.email}'.`,
        );
      }

      verificationResult = {
        email: evtPayload.email,
        evt: evtPayload as unknown as Record<string, unknown>,
        kb: kbPayload,
      };
    } else {
      errorMsg =
        "No verification token was sent by the browser. Traditional verification flow is required.";
    }
  } catch (e) {
    console.error("Verification error:", e);
    errorMsg = e instanceof Error ? e.message : "Failed to verify the token.";
  }
}
---

<MetaOnlyLayout
  title="Email Verification Protocol (EVP) demo"
  description="Demo of an Email Verification Protocol (EVP) Relying Party"
>
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Email Verification Protocol (EVP) demo" />
  <meta
    property="og:description"
    content="Demo of an Email Verification Protocol (EVP) Relying Party"
  />
  <meta name="twitter:card" content="summary" />
  <meta property="twitter:domain" content="rowan.fyi" />
  <meta
    property="twitter:url"
    content={new URL(Astro.url.pathname, Astro.site)}
  />
  <meta name="twitter:title" content="Email Verification Protocol (EVP) demo" />
  <meta
    name="twitter:description"
    content="Demo of an Email Verification Protocol (EVP) Relying Party"
  />
  <link
    rel="icon"
    href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📧</text></svg>"
  />
  <style>
    html {
      font-family: sans-serif;
    }
  </style>
  <h1>Email Verification Protocol (EVP) demo</h1>
  <p>
    Select an email address from the autofill dropdown to trigger verification.
  </p>
  <form method="POST" id="verify-form">
    <label for="email">Email address:</label>
    <input
      type="email"
      id="email"
      name="email"
      autocomplete="email"
      value={submittedEmail || ""}
      placeholder="Use an autofilled email"
      required
    />
    <!-- EVP Hidden Input with Server-Side (or hardcoded) Nonce -->
    <input
      type="hidden"
      name="token"
      nonce="demo-nonce-987654321"
      autocomplete="email-verification-token"
    />
    <button type="submit" id="submit-btn">Sign up</button>
  </form>

  {
    verificationResult && (
      <div>
        <p>Email address: {verificationResult.email}</p>

        <p>Email Verification Token (EVT) Payload</p>
        <pre>
          <code>{JSON.stringify(verificationResult.evt, null, 2)}</code>
        </pre>

        <p>Key Binding JWT (KB-JWT) Payload</p>
        <pre>
          <code>{JSON.stringify(verificationResult.kb, null, 2)}</code>
        </pre>
      </div>
    )
  }

  {errorMsg && <p>{errorMsg}</p>}

  <script>
    const form = document.getElementById("verify-form");
    const submitBtn = document.getElementById("submit-btn");

    if (form && submitBtn) {
      form.addEventListener("submit", () => {
        submitBtn.setAttribute("disabled", "true");
      });
    }
  </script>
</MetaOnlyLayout>
