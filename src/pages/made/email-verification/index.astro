---
export const prerender = false;

Astro.response.headers.set(
  "Origin-Trial",
  "AhXp8ak/QLxZjlTcDhudtMFPwVwV3MrqSIO/OODXG2IknnKycOuqn+z/h195Ob/0B4vF42nTcV8lQbESLVggNQQAAABceyJvcmlnaW4iOiJodHRwczovL3Jvd2FuLmZ5aTo0NDMiLCJmZWF0dXJlIjoiRW1haWxWZXJpZmljYXRpb25Qcm90b2NvbCIsImV4cGlyeSI6MTc5NDg3MzYwMH0=",
);

import MetaOnlyLayout from "@/layouts/MetaOnlyLayout.astro";
import { importJWK, jwtVerify, decodeJwt, decodeProtectedHeader } from "jose";
import type { JWK } from "jose";
import { createHash, randomUUID } from "node:crypto";
import dns from "node:dns/promises";

interface VerificationResult {
  email: string;
  evt: Record<string, unknown>;
  kb: Record<string, unknown>;
}

interface EvtPayload {
  email: string;
  cnf?: {
    jwk?: JWK;
  };
}

/**
 * DNS DELEGATION helper: Verifies that the issuer is authoritative for the submitted email's domain.
 * Under the IETF standard, an email domain delegates verification to an issuer via a DNS TXT record
 * located at `_email-verification.<domain>`.
 *
 * This ensures that a malicious issuer (e.g. attacker.com) cannot sign a forged token
 * asserting ownership of an email at another domain (e.g. victim@gmail.com).
 */
async function verifyIssuerDelegation(
  email: string,
  issuer: string,
): Promise<boolean> {
  const domain = email.split("@")[1];
  if (!domain) return false;

  let issuerHost: string;
  try {
    // Extract the hostname from the issuer URL
    issuerHost = issuer.startsWith("http")
      ? new URL(issuer).hostname.toLowerCase()
      : issuer.toLowerCase();
  } catch {
    issuerHost = issuer.toLowerCase();
  }

  // Local development bypass (e.g., localhost, 127.0.0.1) for frictionless local testing
  if (issuerHost === "localhost" || issuerHost === "127.0.0.1") {
    return true;
  }

  // Self-authoritative match: If the email domain directly matches the issuer's hostname
  if (domain.toLowerCase() === issuerHost) {
    return true;
  }

  try {
    // Perform server-side DNS TXT record lookup under _email-verification.<domain>
    const records = await dns.resolveTxt(`_email-verification.${domain}`);
    for (const record of records) {
      const txt = record.join("");
      if (txt.startsWith("iss=")) {
        const delegatedIssuer = txt.substring(4);
        let delegatedHost = "";
        try {
          delegatedHost = delegatedIssuer.startsWith("http")
            ? new URL(delegatedIssuer).hostname.toLowerCase()
            : delegatedIssuer.toLowerCase();
        } catch {
          delegatedHost = delegatedIssuer.toLowerCase();
        }
        if (delegatedHost === issuerHost) {
          return true; // Match found: delegation is verified!
        }
      }
    }
  } catch (e) {
    console.warn(
      `DNS delegation TXT lookup failed for _email-verification.${domain}:`,
      e,
    );
  }
  return false;
}

let verificationResult: VerificationResult | null = null;
let errorMsg = "";
let submittedEmail = "";

// Cookie and Nonce Configuration
const nonceCookieName = "evp_rp_nonce";
let expectedNonce = Astro.cookies.get(nonceCookieName)?.value;

if (Astro.request.method === "POST") {
  try {
    // Replay Protection: Consume and delete the nonce cookie immediately upon POST receipt.
    Astro.cookies.delete(nonceCookieName, { path: "/" });

    const formData = await Astro.request.formData();
    submittedEmail = formData.get("email") as string;
    const rawToken = formData.get("token") as string;

    if (rawToken) {
      // ==============================================================================
      // STEP 1: TOKEN DECOMPOSITION
      // ==============================================================================
      // Under the SD-JWT Key Binding specification, the combined token is formed by
      // concatenating the Issuer-Signed Token (EVT) and the Holder Key-Binding JWT (KB-JWT)
      // separated by a tilde "~".
      const parts = rawToken.split("~");
      if (parts.length < 2) {
        throw new Error(
          "Invalid token format. Missing Key Binding JWT (KB-JWT) separator '~'.",
        );
      }
      const evtJwt = parts[0];
      const kbJwt = parts[1];

      // Decode the EVT payload to dynamically discover who issued this token.
      const decodedPayload = decodeJwt(evtJwt);
      const iss = decodedPayload.iss;
      if (!iss) {
        throw new Error("EVT is missing the issuer ('iss') claim.");
      }

      // ==============================================================================
      // STEP 2: DNS DELEGATION & AUTHORITY VERIFICATION
      // ==============================================================================
      // Verify that the issuer domain actually has the authority to verify emails for
      // the submitted email address's domain.
      const isAuthoritative = await verifyIssuerDelegation(submittedEmail, iss);
      if (!isAuthoritative) {
        throw new Error(
          `Security Exception: Issuer '${iss}' is not authoritative for the email domain of '${submittedEmail}'.`,
        );
      }

      let evtPayload: EvtPayload;

      // ==============================================================================
      // STEP 3: ISSUER DISCOVERY & EVT SIGNATURE VERIFICATION
      // ==============================================================================
      // 3A. Fetch the issuer's .well-known configurations
      const discoveryUrl = `${iss}/.well-known/email-verification`;
      const metadataResponse = await fetch(discoveryUrl);
      if (!metadataResponse.ok) {
        throw new Error(
          `Failed to discover issuer metadata at ${discoveryUrl}: ${metadataResponse.statusText}`,
        );
      }
      const metadata = await metadataResponse.json();
      const jwksUri = metadata.jwks_uri;
      if (!jwksUri) {
        throw new Error(
          `Issuer metadata at ${discoveryUrl} is missing 'jwks_uri'.`,
        );
      }

      // 3B. Fetch the public JSON Web Key Set (JWKS) used to sign the EVT
      const jwksResponse = await fetch(jwksUri);
      if (!jwksResponse.ok) {
        throw new Error(`Failed to fetch JWKS from ${jwksUri}`);
      }
      const jwksData = await jwksResponse.json();

      // 3C. Validate the EVT signature by checking against the keys in the JWKS
      const headerAlg = decodedPayload?.alg || "EdDSA";
      let verifiedPayload = null;

      for (const jwk of jwksData.keys) {
        try {
          const publicKey = await importJWK(jwk, headerAlg);
          const { payload } = await jwtVerify(evtJwt, publicKey);
          verifiedPayload = payload;
          break; // Key matched and signature verified successfully!
        } catch {
          // Signature verification failed for this key, try the next one
          continue;
        }
      }

      if (!verifiedPayload) {
        throw new Error(
          "Verification error: JWKSNoMatchingKey: no applicable key found in the JSON Web Key Set",
        );
      }
      evtPayload = verifiedPayload as unknown as EvtPayload;

      // ==============================================================================
      // STEP 4: BROWSER EPHEMERAL KEY EXTRACTION
      // ==============================================================================
      // Extract the browser's ephemeral public key from the "cnf" (confirmation) claim.
      // In EVP, the browser generates a key pair, asks the issuer to bind it to the EVT,
      // and then proves ownership of that key pair by signing the KB-JWT.
      const browserJwk = evtPayload.cnf?.jwk;
      if (!browserJwk) {
        throw new Error(
          "EVT payload is missing the browser's ephemeral public key (cnf.jwk).",
        );
      }

      // ==============================================================================
      // STEP 5: KEY BINDING VALIDATION (KB-JWT CHECKS)
      // ==============================================================================
      const kbHeader = decodeProtectedHeader(kbJwt);
      const kbAlg = kbHeader.alg || "ES256";
      const browserPublicKey = await importJWK(browserJwk, kbAlg);

      // 5A. Cryptographic Proof of Possession: Verify the KB-JWT signature using the browser's public key
      const { payload: kbPayload } = await jwtVerify(kbJwt, browserPublicKey);

      // 5B. Audience Verification: Ensure this token was specifically intended for our origin
      const expectedAudience = Astro.url.origin;
      if (kbPayload.aud !== expectedAudience) {
        throw new Error(
          `Key Binding audience mismatch. Expected '${expectedAudience}', but got '${kbPayload.aud}'.`,
        );
      }

      // 5C. Session Nonce Verification: Ensure the nonce matches the one we generated for this rendering
      if (!expectedNonce || kbPayload.nonce !== expectedNonce) {
        throw new Error(
          `Key Binding nonce mismatch or expired session. Expected '${expectedNonce || "N/A"}', but got '${kbPayload.nonce}'.`,
        );
      }

      // 5D. EVT Cryptographic Hash Binding: Match the "sd_hash" inside KB-JWT with the SHA-256
      // hash of the EVT. This prevents an attacker from combining a valid KB-JWT with a different EVT.
      const calculatedHash = createHash("sha256")
        .update(evtJwt + "~")
        .digest("base64url");

      if (kbPayload.sd_hash !== calculatedHash) {
        throw new Error(
          "Key Binding hash mismatch. KB-JWT is not cryptographically bound to this EVT.",
        );
      }

      // ==============================================================================
      // STEP 6: EMAIL IDENTITY MATCH
      // ==============================================================================
      // Ensure the email address verified in the token matches the email inputted in the form.
      if (evtPayload.email !== submittedEmail) {
        throw new Error(
          `Email mismatch: Form input is '${submittedEmail}', but verified token holds '${evtPayload.email}'.`,
        );
      }

      verificationResult = {
        email: evtPayload.email,
        evt: evtPayload as unknown as Record<string, unknown>,
        kb: kbPayload,
      };
    } else {
      errorMsg =
        "No verification token was sent by the browser. Traditional verification flow is required.";
    }
  } catch (e) {
    console.error("Verification error:", e);
    errorMsg = e instanceof Error ? e.message : "Failed to verify the token.";
  }
}

// Always generate a fresh nonce for the next page render
const activeNonce = randomUUID();
Astro.cookies.set(nonceCookieName, activeNonce, {
  path: "/",
  httpOnly: true,
  secure: true,
  sameSite: "lax",
  maxAge: 300, // 5 minutes
});
---

<MetaOnlyLayout
  title="Email Verification Protocol (EVP) demo"
  description="Demo of an Email Verification Protocol (EVP) Relying Party"
>
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Email Verification Protocol (EVP) demo" />
  <meta
    property="og:description"
    content="Demo of an Email Verification Protocol (EVP) Relying Party"
  />
  <meta name="twitter:card" content="summary" />
  <meta property="twitter:domain" content="rowan.fyi" />
  <meta
    property="twitter:url"
    content={new URL(Astro.url.pathname, Astro.site)}
  />
  <meta name="twitter:title" content="Email Verification Protocol (EVP) demo" />
  <meta
    name="twitter:description"
    content="Demo of an Email Verification Protocol (EVP) Relying Party"
  />
  <link
    rel="icon"
    href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📧</text></svg>"
  />
  <style>
    html {
      font-family: sans-serif;
    }
  </style>
  <h1>Email Verification Protocol (EVP) demo</h1>
  <p>
    Select an email address from the autofill dropdown to trigger verification.
  </p>
  <form method="POST" id="verify-form">
    <label for="email">Email address:</label>
    <input
      type="email"
      id="email"
      name="email"
      autocomplete="email"
      value={submittedEmail || ""}
      placeholder="Use an autofilled email"
      required
    />
    <!-- EVP Hidden Input with Server-Side Dynamic Nonce -->
    <input
      type="hidden"
      name="token"
      nonce={activeNonce}
      autocomplete="email-verification-token"
    />
    <button type="submit" id="submit-btn">Sign up</button>
  </form>

  {
    verificationResult && (
      <div>
        <p>Email address: {verificationResult.email}</p>

        <p>Email Verification Token (EVT) Payload</p>
        <pre>
          <code>{JSON.stringify(verificationResult.evt, null, 2)}</code>
        </pre>

        <p>Key Binding JWT (KB-JWT) Payload</p>
        <pre>
          <code>{JSON.stringify(verificationResult.kb, null, 2)}</code>
        </pre>
      </div>
    )
  }

  {errorMsg && <p>{errorMsg}</p>}

  <script>
    const form = document.getElementById("verify-form");
    const submitBtn = document.getElementById("submit-btn");

    if (form && submitBtn) {
      form.addEventListener("submit", () => {
        submitBtn.setAttribute("disabled", "true");
      });
    }
  </script>
</MetaOnlyLayout>
