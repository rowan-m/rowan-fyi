---
import DefaultHead from "@/components/DefaultHead.astro";
import DefaultBodyLayout from "@/layouts/DefaultBodyLayout.astro";

// Glob static HTML-based glitch projects
const staticItems = import.meta.glob("/public/made/*/index.html", {
  eager: true,
});

// Glob Astro-based projects
const astroItems = import.meta.glob("/src/pages/made/*/index.astro", {
  eager: true,
});

// Map static items to layout-compatible format
const staticList = Object.keys(staticItems).map((key) => {
  const slug = key.split("/").filter(Boolean).at(-2) || "";
  return {
    name: slug,
    href: `/made/${slug}/`,
  };
});

// Map Astro-based items to layout-compatible format
const astroList = Object.keys(astroItems).map((key) => {
  const slug = key.split("/").filter(Boolean).at(-2) || "";
  return {
    name: slug,
    href: `/made/${slug}/`,
  };
});

// Merge both static and Astro-based lists
const mergedList = [...astroList, ...staticList];

// Sort alphabetically by name
mergedList.sort((a, b) => a.name.localeCompare(b.name));
---

<!doctype html>
<html lang="en">
  <DefaultHead title="Made by Rowan" description="Things I've made" />
  <DefaultBodyLayout>
    <main>
      <h1>Things I've made</h1>
      <p>
        This is a quick, dirty, and evolving import of projects from <a
          href="https://glitch.com">Glitch</a
        >. There are probably a few absolute links in here which means things
        might not work. Feel free to ping me on your preferred social network if
        you find something that's broken.
      </p>
      <ul>
        {
          mergedList.map((item) => (
            <li>
              <a href={item.href}>{item.name}</a>
            </li>
          ))
        }
      </ul>
    </main>
  </DefaultBodyLayout>
</html>
