---
import fs from "node:fs";
import path from "node:path";
import DefaultHead from "@/components/DefaultHead.astro";
import DefaultBodyLayout from "@/layouts/DefaultBodyLayout.astro";

export const prerender = true;

// Read static directories inside public/made/
let staticDirs: string[] = [];
try {
  const staticPath = path.resolve("public/made");
  staticDirs = fs.readdirSync(staticPath).filter((file) => {
    return fs.statSync(path.join(staticPath, file)).isDirectory();
  });
} catch (e) {
  console.warn("Could not read public/made directory", e);
}

// Read Astro directories inside src/pages/made/
let astroDirs: string[] = [];
try {
  const astroPath = path.resolve("src/pages/made");
  astroDirs = fs.readdirSync(astroPath).filter((file) => {
    return (
      file !== "index.astro" &&
      fs.statSync(path.join(astroPath, file)).isDirectory()
    );
  });
} catch (e) {
  console.warn("Could not read src/pages/made directory", e);
}

// Map both lists to a common structure
const staticList = staticDirs.map((slug) => ({
  name: slug,
  href: `/made/${slug}/`,
}));

const astroList = astroDirs.map((slug) => ({
  name: slug,
  href: `/made/${slug}/`,
}));

// Merge both static and Astro-based lists, deduplicating by folder name (slug)
const mergedMap = new Map();
for (const item of [...astroList, ...staticList]) {
  mergedMap.set(item.name, item);
}
const mergedList = Array.from(mergedMap.values());

// Sort alphabetically by name
mergedList.sort((a, b) => a.name.localeCompare(b.name));
---

<!doctype html>
<html lang="en">
  <DefaultHead title="Made by Rowan" description="Things I've made" />
  <DefaultBodyLayout>
    <main>
      <h1>Things I've made</h1>
      <p>
        This is a quick, dirty, and evolving import of projects from <a
          href="https://glitch.com">Glitch</a
        >. There are probably a few absolute links in here which means things
        might not work. Feel free to ping me on your preferred social network if
        you find something that's broken.
      </p>
      <ul>
        {
          mergedList.map((item) => (
            <li>
              <a href={item.href}>{item.name}</a>
            </li>
          ))
        }
      </ul>
    </main>
  </DefaultBodyLayout>
</html>
